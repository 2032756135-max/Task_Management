# SMTP 邮件配置
# 以下是邮件提醒功能所需的配置，将此文件复制为 .env 并填入你的 SMTP 信息

# SMTP 服务器地址
SMTP_HOST=smtp.gmail.com

# SMTP 服务器端口（587 用于 TLS，465 用于 SSL）
SMTP_PORT=587

# SMTP 账户邮箱
SMTP_USER=your-email@gmail.com

# SMTP 账户密码或应用专用密码
# 对于 Gmail，请使用应用专用密码（需要启用两步验证）
# 详见：https://support.google.com/accounts/answer/185833
SMTP_PASS=your-app-password

# 可选：服务器端口
PORT=3000

# 常见 SMTP 服务商配置：
# Gmail:         smtp.gmail.com:587 (TLS) 或 smtp.gmail.com:465 (SSL)
# QQ邮箱:        smtp.qq.com:465 (SSL)
# 163邮箱:       smtp.163.com:465 (SSL)
# 阿里邮箱:      smtp.aliyun.com:465 (SSL)
# Outlook:       smtp-mail.outlook.com:587 (TLS)
